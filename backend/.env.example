# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Base de Datos (MongoDB Atlas) ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Seguridad ─────────────────────────────────────────────────────────────────
JWT_SECRET=tu_secreto_largo_y_seguro_aqui
JWT_EXPIRES_IN=7d

# Orígenes CORS permitidos (separados por comas sin espacios)
ALLOWED_ORIGINS=https://debuta.online,https://www.debuta.online

# ── Cloudinary (Almacenamiento de fotos) ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Correo Electrónico (Recuperación de contraseña) ───────────────────────────
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_password_de_aplicacion_gmail

# ── Panel de Administración (Configuración de acceso inicial) ──────────────────
ADMIN_EMAIL=admin@debuta.com
ADMIN_USERNAME=admin

# ── Autenticación de Terceros ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
FACEBOOK_APP_ID=tu_facebook_app_id
FACEBOOK_APP_SECRET=tu_facebook_app_secret

# ── Atlas Admin API (Opcional - solo para auto-whitelist de IPs en dev) ──────
# En producción (VPS con IP fija) agrega la IP directamente en MongoDB Atlas:
# MongoDB Atlas → Network Access → Add IP Address → <IP_FIJA_DEL_VPS>
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
ATLAS_PROJECT_ID=

# ── TURN Server para WebRTC (Llamadas y Videollamadas) ────────────────────────
# Registro gratis en https://dashboard.metered.ca  (50 GB/mes sin costo)
# 1. Crea una app en el dashboard
# 2. Ve a "Credentials" y copia el App Name y el API Key
# Si están vacíos, el sistema usa servidores TURN públicos de respaldo (menos confiables)
METERED_APP_NAME=
METERED_API_KEY=
